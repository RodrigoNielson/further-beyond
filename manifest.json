{
  "manifest_version": 3,
  "name": "Further Beyond",
  "version": "0.0.71",
  "description": "Adds character-page indicators and slot-based inventory tracking on D&D Beyond.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Further Beyond",
    "default_popup": "content/popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.dndbeyond.com/characters/*"
      ],
      "js": [
        "content/further-dice-sdk.js",
        "content/content.js"
      ],
      "css": [
        "content/content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/wizard.png",
        "content/page-bridge.js"
      ],
      "matches": [
        "https://www.dndbeyond.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}